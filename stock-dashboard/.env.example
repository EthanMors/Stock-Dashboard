# Copy this file to .env and fill in your keys
MASSIVE_API_KEY=your_api_key_here
REDDIT_USERNAME=your_reddit_username
GEMINI_API_KEY=your_gemini_api_key

# Webull credentials (used by the Portfolio Positions page)
# If omitted, you will be prompted at runtime
WEBULL_EMAIL=your_webull_email_here
WEBULL_PASSWORD=your_webull_password_here
# Optional: label shown for this login device in your Webull account
WEBULL_DEVICE_NAME=Stock-Dashboard
