# Copy this file to .env and fill in your keys
MASSIVE_API_KEY=your_api_key_here
REDDIT_USERNAME=your_reddit_username
GEMINI_API_KEY=your_gemini_api_key

# Webull Official OpenAPI credentials
# ─────────────────────────────────────────────────────────────────────────────
# 1. Register at https://developer.webull.com and create an API application.
# 2. Copy the APP_KEY and APP_SECRET shown there into the fields below.
# 3. New API keys start in "Pending" status — open the Webull mobile app,
#    go to Profile → Settings → API Management, and tap Authorize.
# 4. Once authorized, the key is valid for 15 days.  Renew before it expires.
# 5. ACCOUNT_ID is your Webull brokerage account number (visible in the app
#    under Account → Account Info, or in the developer portal).
# 6. REGION_ID is "us" for US accounts or "hk" for Hong Kong accounts.
WEBULL_APP_KEY=your_app_key_here
WEBULL_APP_SECRET=your_app_secret_here
WEBULL_ACCOUNT_ID=your_account_id_here
WEBULL_REGION_ID=us
